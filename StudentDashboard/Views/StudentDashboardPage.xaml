<Window x:Class="StudentPerformanceDashboard.StudentDashboardPage"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:chart="http://schemas.syncfusion.com/wpf"
        xmlns:gauge="http://schemas.syncfusion.com/wpf"
        xmlns:local="clr-namespace:StudentPerformanceDashboard"
        xmlns:editors="http://schemas.syncfusion.com/wpf">

    <Window.Resources>

        <!-- ================= PARCHMENT THEME PALETTE ================= -->
        <SolidColorBrush x:Key="MainBackgroundBrush" Color="#FFF8F3EB"/>
        <!-- a bit lighter -->
        <SolidColorBrush x:Key="CardGlassFillBrush" Color="#60FFFBEB"/>
        <SolidColorBrush x:Key="NavGlassFillBrush"  Color="#4CFFFBEB"/>
        <SolidColorBrush x:Key="CardBorderBrush"    Color="#33B45309"/>
        <!-- lighter border -->
        <SolidColorBrush x:Key="GlowBrush"          Color="#33F97316"/>
        <!-- stronger glow -->

        <!-- #a8a29e -->
        <!-- rgba(249,115,22,0.15) -->

        <!-- Core accents -->
        <SolidColorBrush x:Key="RadiantOrangeBrush" Color="#FFF97316"/>
        <!-- primary -->
        <SolidColorBrush x:Key="CrimsonRoseBrush"   Color="#FFE11D48"/>
        <!-- secondary -->
        <SolidColorBrush x:Key="GoldenAmberBrush"   Color="#FFF59E0B"/>
        <!-- tertiary -->
        <SolidColorBrush x:Key="TextPrimaryBrush"   Color="#FF292524"/>
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#FF6B625B"/>

        <!-- Functional -->
        <SolidColorBrush x:Key="NotAttendedBrush" Color="#FFD6D3D1"/>
        <!-- #d6d3d1 -->

        <!-- Grade palette -->
        <SolidColorBrush x:Key="GradeABrush" Color="#FFF97316"/>
        <SolidColorBrush x:Key="GradeBBrush" Color="#FFFB923C"/>
        <SolidColorBrush x:Key="GradeCBrush" Color="#FFF59E0B"/>
        <SolidColorBrush x:Key="GradeDBrush" Color="#FFE11D48"/>
        <SolidColorBrush x:Key="GradeFBrush" Color="#FF9A3412"/>

        <!-- =============== CONVERTERS =============== -->
        <local:OneItemVisibleConverter x:Key="OneItemVisibleConverter"/>
        <local:MultipleItemsVisibleConverter x:Key="MultipleItemsVisibleConverter"/>

        <!-- =============== CHART HELPERS =============== -->

        <DataTemplate x:Key="MarkerCircleTemplate">
            <Ellipse Width="8" Height="8"
                     Fill="{StaticResource RadiantOrangeBrush}"
                     Stroke="#FFFFFFFF"
                     StrokeThickness="1"/>
        </DataTemplate>

        <DataTemplate x:Key="dataLabelTemplate">
            <Ellipse Width="10" Height="10" Fill="{StaticResource GoldenAmberBrush}"/>
        </DataTemplate>

        <Style x:Key="ToolTipBehaviorStyle" TargetType="Path">
            <Setter Property="Fill"   Value="{StaticResource CardGlassFillBrush}"/>
            <Setter Property="Stroke" Value="{StaticResource RadiantOrangeBrush}"/>
            <Setter Property="StrokeThickness" Value="2"/>
        </Style>

        <!-- Pie / line palettes (warm) -->
        <chart:ChartColorModel x:Key="PieBrushesParchment">
            <chart:ChartColorModel.CustomBrushes>
                <SolidColorBrush Color="#F97316"/>
                <SolidColorBrush Color="#FB923C"/>
                <SolidColorBrush Color="#E11D48"/>
            </chart:ChartColorModel.CustomBrushes>
        </chart:ChartColorModel>

        <chart:ChartColorModel x:Key="LineBrushesParchment">
            <chart:ChartColorModel.CustomBrushes>
                <SolidColorBrush Color="#E11D48"/>
            </chart:ChartColorModel.CustomBrushes>
        </chart:ChartColorModel>

        <!-- =============== TYPOGRAPHY =============== -->

        <Style x:Key="TitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="32"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="TextOptions.TextFormattingMode" Value="Ideal"/>
        </Style>

        <Style x:Key="SectionHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        </Style>

        <Style TargetType="Line" x:Key="lineStyle">
            <Setter Property="StrokeThickness" Value="0"/>
        </Style>

        <!-- Brushes used only for combo visual states -->
        <SolidColorBrush x:Key="ComboNormalBrush"    Color="#4CFFFBEB"/>
        <SolidColorBrush x:Key="ComboHoverBrush"     Color="#66FFFBEB"/>
        <SolidColorBrush x:Key="ComboPressedBrush"   Color="#80FFEDD5"/>
        <SolidColorBrush x:Key="ComboDisabledBrush"  Color="#33E5E0D5"/>
        <SolidColorBrush x:Key="ComboBorderBrush"    Color="#33B45309"/>
        <SolidColorBrush x:Key="ComboFocusBorder"    Color="#FFF97316"/>
        <SolidColorBrush x:Key="ComboArrowBrush"     Color="#FF9A3412"/>

        <!-- Template for the drop-down button glyph -->
        <Geometry x:Key="ComboArrowGeometry">M 0 0 L 1 0 0.5 1 Z</Geometry>

        <Style x:Key="ParchmentComboStyle" TargetType="editors:ComboBoxAdv">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="FontSize"   Value="13"/>
            <Setter Property="Padding"    Value="6,2"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{StaticResource ComboBorderBrush}"/>
            <Setter Property="Background"  Value="{StaticResource ComboNormalBrush}"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="editors:ComboBoxAdv">
                        <Grid x:Name="Root">
                            <!-- outer glass -->
                            <Border x:Name="Border"
                            CornerRadius="18"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition/>
                                        <ColumnDefinition Width="32"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Content (text) -->
                                    <ContentPresenter Margin="{TemplateBinding Padding}"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Left"
                                              RecognizesAccessKey="True"/>

                                    <!-- Drop-down button -->
                                    <Border x:Name="DropDownButton"
                                    Grid.Column="1"
                                    Background="Transparent">
                                        <Grid>
                                            <Path Data="{StaticResource ComboArrowGeometry}"
                                          Width="10" Height="6"
                                          Stretch="Fill"
                                          Fill="{StaticResource ComboArrowBrush}"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                                        </Grid>
                                    </Border>
                                </Grid>
                            </Border>

                            <!-- focus ring -->
                            <Border x:Name="FocusVisual"
                            CornerRadius="18"
                            BorderThickness="1.5"
                            BorderBrush="{StaticResource ComboFocusBorder}"
                            Opacity="0"
                            Margin="1"/>
                        </Grid>

                        <ControlTemplate.Triggers>
                            <!-- DISABLED -->
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Border" Property="Background" Value="{StaticResource ComboDisabledBrush}"/>
                                <Setter TargetName="Border" Property="BorderBrush" Value="#22000000"/>
                                <Setter Property="Foreground" Value="#66000000"/>
                            </Trigger>
                        </ControlTemplate.Triggers>

                        <!-- VISUAL STATES -->

                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <Style x:Key="ParchmentComboItemStyle" TargetType="editors:ComboBoxItemAdv">
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Background" Value="#00FFFFFF"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#33FFFBEB"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#FFF97316"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Foreground" Value="#66000000"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- glass background + glow -->
        <LinearGradientBrush x:Key="CardGlassBackgroundBrush"
                     StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#CCFFFBEB" Offset="0.0"/>
            <GradientStop Color="#80FFEDD5" Offset="0.45"/>
            <GradientStop Color="#4CFFFBEB" Offset="1.0"/>
        </LinearGradientBrush>

        <DropShadowEffect x:Key="CardShadowEffect"
                  Color="#80F97316"
                  BlurRadius="40"
                  ShadowDepth="6"
                  Opacity="0.9"/>

        <Style x:Key="GlassCardStyle" TargetType="Border">
            <Setter Property="CornerRadius"    Value="28"/>
            <Setter Property="Padding"         Value="22"/>
            <Setter Property="Background"      Value="White"/>
            <Setter Property="BorderBrush"     Value="#40B45309"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style x:Key="ScoreTileStyle" TargetType="Border" BasedOn="{StaticResource GlassCardStyle}">
            <Setter Property="Padding" Value="18"/>
            <Setter Property="Margin"  Value="10,10,10,0"/>
        </Style>


        <Style x:Key="ScoreValueStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="22"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="ScoreLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,5,0,0"/>
        </Style>

        <!-- =============== DROPDOWNS =============== -->

        <Style x:Key="DarkComboStyle" TargetType="editors:ComboBoxAdv">
            <Setter Property="Background" Value="{StaticResource NavGlassFillBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource CardBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1.2"/>
            <Setter Property="Padding" Value="4"/>
        </Style>

        <SolidColorBrush x:Key="DropdownHoverBrush"    Color="#26F97316"/>
        <!-- light glow -->
        <SolidColorBrush x:Key="DropdownSelectedBrush" Color="#FFF97316"/>
        <SolidColorBrush x:Key="DropdownPressedBrush"  Color="#FFF59E0B"/>

        <DataTemplate x:Key="SubjectItemTemplate">
            <StackPanel Orientation="Horizontal" Margin="8,4">
                <TextBlock Text="&#xE8D2;"
                           FontFamily="Segoe MDL2 Assets"
                           Foreground="{StaticResource RadiantOrangeBrush}"
                           Margin="0,0,8,0"/>
                <TextBlock Text="{Binding Name}"
                           Foreground="{StaticResource TextPrimaryBrush}"/>
            </StackPanel>
        </DataTemplate>

        <DataTemplate x:Key="YearItemTemplate">
            <TextBlock Text="{Binding}"
                       Foreground="{StaticResource TextPrimaryBrush}"
                       Margin="8,4"/>
        </DataTemplate>

        <Style x:Key="DarkComboBoxItemStyle" TargetType="editors:ComboBoxItemAdv">
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Background" Value="{StaticResource NavGlassFillBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource CardBorderBrush}"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource DropdownHoverBrush}"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{StaticResource DropdownSelectedBrush}"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
                <Trigger Property="IsKeyboardFocusWithin" Value="True">
                    <Setter Property="Background" Value="{StaticResource DropdownHoverBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

    </Window.Resources>

    <!-- ================= ROOT LAYOUT ================= -->
    <ScrollViewer>
        <Grid Margin="10,0,10,0" >
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>


            <!-- Header -->
            <Grid Grid.Row="0" Margin="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="&#xE7BE;" VerticalAlignment="Center" Margin="0,0,10,0"
                               FontFamily="Segoe MDL2 Assets"
                               Foreground="{StaticResource RadiantOrangeBrush}"
                               FontSize="34"/>
                        <TextBlock Style="{StaticResource TitleStyle}" Text="Student Performance"/>
                    </StackPanel>
                </StackPanel>

                <TextBlock Grid.Column="1"
                       Text="Subject"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       Margin="20,10,10,10"
                       VerticalAlignment="Center"/>

                <editors:ComboBoxAdv Grid.Column="2"
                                 Width="160"
                                 Style="{StaticResource DarkComboStyle}"
                                 DisplayMemberPath="Name"
                                 ItemsSource="{Binding Subjects}"
                                 DefaultText="Select Subject"
                                 IsEditable="False"
                                 ItemContainerStyle="{StaticResource ParchmentComboItemStyle}"
                                 SelectedItem="{Binding SelectedSubject, Mode=TwoWay}"
                                 VerticalAlignment="Center"
                                 Margin="0,0,20,0"/>

                <TextBlock Grid.Column="3"
                       Text="Year"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       Margin="0,10,10,10"
                       VerticalAlignment="Center"/>

                <editors:ComboBoxAdv Grid.Column="4"
                                 Width="120"
                                 Style="{StaticResource DarkComboStyle}"
                                 VerticalAlignment="Center"
                                 ItemsSource="{Binding Years}"
                                 ItemTemplate="{StaticResource YearItemTemplate}"
                                 ItemContainerStyle="{StaticResource DarkComboBoxItemStyle}"
                                 SelectedItem="{Binding SelectedYear, Mode=TwoWay}"/>
            </Grid>

            <!-- Score tiles -->
            <Grid Grid.Row="1" Margin="0,0,0,25">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource ScoreTileStyle}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource ScoreValueStyle}">
                        <Run Text="{Binding PhysEdScore, Mode=OneWay}"/>
                        </TextBlock>
                        <TextBlock Text="PhysEd" Style="{StaticResource ScoreLabelStyle}"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource ScoreTileStyle}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource ScoreValueStyle}">
                        <Run Text="{Binding ArtsScore,Mode=OneWay}"/>
                        </TextBlock>
                        <TextBlock Text="Arts" Style="{StaticResource ScoreLabelStyle}"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Style="{StaticResource ScoreTileStyle}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource ScoreValueStyle}">
                        <Run Text="{Binding EnglishScore, Mode=OneWay}"/>
                        </TextBlock>
                        <TextBlock Text="English" Style="{StaticResource ScoreLabelStyle}"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="3" Style="{StaticResource ScoreTileStyle}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource ScoreValueStyle}">
                        <Run Text="{Binding MathsScore, Mode=OneWay}"/>
                        </TextBlock>
                        <TextBlock Text="Maths" Style="{StaticResource ScoreLabelStyle}"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="4" Style="{StaticResource ScoreTileStyle}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource ScoreValueStyle}">
                        <Run Text="{Binding ScienceScore, Mode=OneWay}"/>
                        </TextBlock>
                        <TextBlock Text="Science" Style="{StaticResource ScoreLabelStyle}"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Main content -->
            <Grid Grid.Row="2" Margin="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="2*"/>
                </Grid.ColumnDefinitions>

                <!-- Left column -->
                <Grid Grid.Row="0" Grid.Column="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="3*"/>
                        <RowDefinition Height="2*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                        Style="{StaticResource GlassCardStyle}"
                        Margin="0,0,15,0">
                        <StackPanel>
                            <TextBlock Text="Student Performance"
                                   Style="{StaticResource SectionHeaderStyle}"
                                   HorizontalAlignment="Center"/>

                            <chart:SfChart VerticalAlignment="Center"
                                       Background="Transparent">
                                <chart:SfChart.Legend>
                                    <chart:ChartLegend DockPosition="Bottom"
                           ToggleSeriesVisibility="True"/>
                                </chart:SfChart.Legend>

                                <chart:PieSeries ItemsSource="{Binding GenderParticipationPie}"
                                             XBindingPath="Label"
                                             YBindingPath="Value"
                                             Label="Gender Participation"
                                             Palette="Custom"
                                             ExplodeRadius="5"
                                             ExplodeIndex="0"
                                             ExplodeOnMouseClick="True">
                                    <!-- Custom warm palette for each slice -->
                                    <chart:PieSeries.ColorModel>
                                        <chart:ChartColorModel>
                                            <chart:ChartColorModel.CustomBrushes>
                                                <!-- Male -->
                                                <SolidColorBrush Color="#F97316"/>
                                                <!-- Female -->
                                                <SolidColorBrush Color="#E11D48"/>
                                                <!-- Others -->
                                                <SolidColorBrush Color="#F59E0B"/>
                                            </chart:ChartColorModel.CustomBrushes>
                                        </chart:ChartColorModel>
                                    </chart:PieSeries.ColorModel>

                                    <chart:PieSeries.AdornmentsInfo>
                                        <chart:ChartAdornmentInfo ShowLabel="True"
                                      LabelPosition="Inner"
                                      Foreground="White"
                                      SegmentLabelContent="Percentage"/>
                                    </chart:PieSeries.AdornmentsInfo>
                                </chart:PieSeries>
                            </chart:SfChart>

                        </StackPanel>
                    </Border>

                    <Border Grid.Row="1"
                        Style="{StaticResource GlassCardStyle}"
                        Margin="0,15,15,0"
                        Padding="20,0">
                        <StackPanel>
                            <TextBlock Text="Students per Year"
                                   Style="{StaticResource ScoreLabelStyle}"
                                   HorizontalAlignment="Center"/>
                            <chart:SfChart Margin="0,6,0,0"
                                       Background="Transparent"
                                       ColorModel="{StaticResource LineBrushesParchment}">
                                <chart:SfChart.PrimaryAxis>
                                    <chart:CategoryAxis ShowGridLines="False"
                                                    PlotOffsetStart="10"
                                                    PlotOffsetEnd="10">
                                        <chart:CategoryAxis.LabelStyle>
                                            <chart:LabelStyle Foreground="{StaticResource TextSecondaryBrush}"
                                                          FontSize="11"/>
                                        </chart:CategoryAxis.LabelStyle>
                                    </chart:CategoryAxis>
                                </chart:SfChart.PrimaryAxis>
                                <chart:SfChart.SecondaryAxis>
                                    <chart:NumericalAxis ShowGridLines="False">
                                        <chart:NumericalAxis.LabelStyle>
                                            <chart:LabelStyle Foreground="{StaticResource TextSecondaryBrush}"
                                                          FontSize="12"/>
                                        </chart:NumericalAxis.LabelStyle>
                                    </chart:NumericalAxis>
                                </chart:SfChart.SecondaryAxis>
                                <chart:SplineSeries ItemsSource="{Binding StudentsPerYear}"
                                                XBindingPath="Year"
                                                YBindingPath="Students"
                                                Label="Students per Year"
                                                Interior="#E11D48"
                                                StrokeThickness="2">
                                    <chart:SplineSeries.AdornmentsInfo>
                                        <chart:ChartAdornmentInfo ShowLabel="True"
                                                              LabelTemplate="{StaticResource MarkerCircleTemplate}"/>
                                    </chart:SplineSeries.AdornmentsInfo>
                                </chart:SplineSeries>
                            </chart:SfChart>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Center column -->
                <Grid Grid.Row="0" Grid.Column="1" Margin="10,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="3*"/>
                        <RowDefinition Height="2*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                        Style="{StaticResource GlassCardStyle}">
                        <StackPanel>
                            <TextBlock Text="Participation Rate by Subject (%)"
                                   Style="{StaticResource SectionHeaderStyle}"/>
                            <Grid Margin="0,0,0,0">

                                <chart:SfChart
                                           Background="Transparent"
                                           Visibility="{Binding FilteredParticipationRates.Count,
                                                                Converter={StaticResource MultipleItemsVisibleConverter}}">
                                    <chart:SfChart.PrimaryAxis>
                                        <chart:CategoryAxis ShowGridLines="False">
                                            <chart:CategoryAxis.LabelStyle>
                                                <chart:LabelStyle Foreground="{StaticResource TextSecondaryBrush}"
                                                              FontSize="12"/>
                                            </chart:CategoryAxis.LabelStyle>
                                        </chart:CategoryAxis>
                                    </chart:SfChart.PrimaryAxis>
                                    <chart:SfChart.SecondaryAxis>
                                        <chart:NumericalAxis ShowGridLines="False" Maximum="100">
                                            <chart:NumericalAxis.LabelStyle>
                                                <chart:LabelStyle Foreground="{StaticResource TextSecondaryBrush}"
                                                              FontSize="12"/>
                                            </chart:NumericalAxis.LabelStyle>
                                        </chart:NumericalAxis>
                                    </chart:SfChart.SecondaryAxis>

                                    <!-- grade-like column colors -->
                                    <chart:ColumnSeries ItemsSource="{Binding FilteredParticipationRates}"
                                                    XBindingPath="Subject.Name"
                                                    YBindingPath="Rate" Palette="Custom"
                                                    Label="Participation">
                                        <chart:ColumnSeries.ColorModel>
                                            <chart:ChartColorModel>
                                                <chart:ChartColorModel.CustomBrushes>
                                                    <SolidColorBrush Color="#F97316"/>
                                                    <SolidColorBrush Color="#FB923C"/>
                                                    <SolidColorBrush Color="#F59E0B"/>
                                                    <SolidColorBrush Color="#E11D48"/>
                                                    <SolidColorBrush Color="#9A3412"/>
                                                </chart:ChartColorModel.CustomBrushes>
                                            </chart:ChartColorModel>
                                        </chart:ColumnSeries.ColorModel>
                                        <chart:ColumnSeries.AdornmentsInfo>
                                            <chart:ChartAdornmentInfo ShowLabel="True"
                                                                  LabelTemplate="{StaticResource dataLabelTemplate}"
                                                                  Foreground="{StaticResource TextSecondaryBrush}"/>
                                        </chart:ColumnSeries.AdornmentsInfo>
                                    </chart:ColumnSeries>
                                </chart:SfChart>

                                <!-- Single subject gauge -->
                                <gauge:SfCircularGauge VerticalContentAlignment="Top"
                                                   VerticalAlignment="Top"
                                                   Visibility="{Binding FilteredParticipationRates.Count,
                                                                        Converter={StaticResource OneItemVisibleConverter}}"
                                                   Background="Transparent"
                                                   Foreground="{StaticResource TextSecondaryBrush}">
                                    <gauge:SfCircularGauge.Annotations>
                                        <gauge:GaugeAnnotation VerticalContentAlignment="Top"
                                                           Offset="0.1"
                                                           Angle="270">
                                            <StackPanel HorizontalAlignment="Center"
                                                    VerticalAlignment="Center">
                                                <TextBlock Text="{Binding FilteredParticipationRates[0].Subject.Name}"
                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                       FontSize="24"
                                                       HorizontalAlignment="Center"/>
                                                <TextBlock Text="{Binding FilteredParticipationRates[0].Rate}"
                                                       Foreground="{StaticResource TextPrimaryBrush}"
                                                       FontSize="34"
                                                       FontWeight="Bold"
                                                       HorizontalAlignment="Center"/>
                                            </StackPanel>
                                        </gauge:GaugeAnnotation>
                                    </gauge:SfCircularGauge.Annotations>

                                    <gauge:SfCircularGauge.Scales>
                                        <!-- Background ring -->
                                        <gauge:CircularScale StartAngle="180"
                                                         ShowLabels="False"
                                                         ShowRim="False"
                                                         SweepAngle="180"
                                                         Radius="0.8"
                                                         ShowTicks="False"
                                                         ShowFirstLabel="False">
                                            <gauge:CircularScale.Pointers>
                                                <gauge:CircularPointer RangePointerStrokeThickness="25"
                                                                   PointerType="RangePointer"
                                                                   RangeCap="Both"
                                                                   RangePointerStroke="{StaticResource GlowBrush}"
                                                                   EnableAnimation="False"
                                                                   Value="100"/>
                                            </gauge:CircularScale.Pointers>
                                        </gauge:CircularScale>

                                        <!-- Active value ring -->
                                        <gauge:CircularScale SweepAngle="180"
                                                         ShowLabels="False"
                                                         StartAngle="180"
                                                         Radius="0.8"
                                                         LabelStroke="{StaticResource TextSecondaryBrush}"
                                                         ShowTicks="False"
                                                         ShowRim="False"
                                                         BindRangeStrokeToLabels="True">
                                            <gauge:CircularScale.Pointers>
                                                <gauge:CircularPointer RangePointerStrokeThickness="25"
                                                                   PointerType="RangePointer"
                                                                   RangePointerStroke="{StaticResource RadiantOrangeBrush}"
                                                                   RangeCap="Both"
                                                                   EnableAnimation="True"
                                                                   Value="{Binding FilteredParticipationRates[0].Rate}"/>
                                            </gauge:CircularScale.Pointers>
                                        </gauge:CircularScale>
                                    </gauge:SfCircularGauge.Scales>
                                </gauge:SfCircularGauge>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="1"
                        Style="{StaticResource GlassCardStyle}"
                        Margin="0,15,15,0">
                        <StackPanel>
                            <TextBlock Text="Semester Grade Trends"
                                   Style="{StaticResource SectionHeaderStyle}"/>
                            <chart:SfChart 
                                       Margin="0,10"
                                       Background="Transparent"
                                       ColorModel="{StaticResource LineBrushesParchment}">
                                <chart:SfChart.PrimaryAxis>
                                    <chart:CategoryAxis ShowGridLines="False"
                                                    PlotOffsetStart="10"
                                                    PlotOffsetEnd="10">
                                        <chart:CategoryAxis.LabelStyle>
                                            <chart:LabelStyle Foreground="{StaticResource TextSecondaryBrush}"
                                                          FontSize="12"/>
                                        </chart:CategoryAxis.LabelStyle>
                                    </chart:CategoryAxis>
                                </chart:SfChart.PrimaryAxis>
                                <chart:SfChart.SecondaryAxis>
                                    <chart:NumericalAxis ShowGridLines="False">
                                        <chart:NumericalAxis.LabelStyle>
                                            <chart:LabelStyle Foreground="{StaticResource TextSecondaryBrush}"
                                                          FontSize="12"/>
                                        </chart:NumericalAxis.LabelStyle>
                                    </chart:NumericalAxis>
                                </chart:SfChart.SecondaryAxis>
                                <chart:SplineSeries ItemsSource="{Binding FilteredSemesterTrend}"
                                                XBindingPath="Label"
                                                YBindingPath="Value"
                                                StrokeThickness="3"
                                                Interior="#E11D48">
                                    <chart:SplineSeries.AdornmentsInfo>
                                        <chart:ChartAdornmentInfo ShowLabel="True"
                                                              LabelTemplate="{StaticResource MarkerCircleTemplate}"/>
                                    </chart:SplineSeries.AdornmentsInfo>
                                </chart:SplineSeries>
                            </chart:SfChart>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Right column -->
                <Grid Grid.Row="0" Grid.Column="2" Margin="15,0,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                        Style="{StaticResource GlassCardStyle}"
                        Margin="0,0,0,15">
                        <StackPanel>
                            <TextBlock Text="Examination Results by Subject"
                                   Style="{StaticResource SectionHeaderStyle}"/>
                            <chart:SfChart Margin="0,10"
                                       MaxHeight="345"
                                       Background="Transparent">
                                <chart:SfChart.PrimaryAxis>
                                    <chart:CategoryAxis ShowGridLines="False">
                                        <chart:CategoryAxis.LabelStyle>
                                            <chart:LabelStyle Foreground="{StaticResource TextSecondaryBrush}"
                                                          FontSize="12"/>
                                        </chart:CategoryAxis.LabelStyle>
                                    </chart:CategoryAxis>
                                </chart:SfChart.PrimaryAxis>
                                <chart:SfChart.SecondaryAxis>
                                    <chart:NumericalAxis ShowGridLines="False">
                                        <chart:NumericalAxis.LabelStyle>
                                            <chart:LabelStyle Foreground="{StaticResource TextSecondaryBrush}"
                                                          FontSize="12"/>
                                        </chart:NumericalAxis.LabelStyle>
                                    </chart:NumericalAxis>
                                </chart:SfChart.SecondaryAxis>
                                <chart:SfChart.Legend>
                                    <chart:ChartLegend ToggleSeriesVisibility="True"/>
                                </chart:SfChart.Legend>

                                <!-- Pass -->
                                <chart:ColumnSeries ItemsSource="{Binding FilteredExamResults}"
                                                XBindingPath="Subject.Name"
                                                YBindingPath="Pass"
                                                SegmentSpacing="0.1"
                                                Interior="{StaticResource RadiantOrangeBrush}"
                                                Label="Pass">
                                    <chart:ColumnSeries.AdornmentsInfo>
                                        <chart:ChartAdornmentInfo ShowLabel="False"/>
                                    </chart:ColumnSeries.AdornmentsInfo>
                                </chart:ColumnSeries>

                                <!-- Fail -->
                                <chart:ColumnSeries ItemsSource="{Binding FilteredExamResults}"
                                                XBindingPath="Subject.Name"
                                                YBindingPath="Fail"
                                                SegmentSpacing="0.1"
                                                Interior="{StaticResource CrimsonRoseBrush}"
                                                Label="Fail">
                                    <chart:ColumnSeries.AdornmentsInfo>
                                        <chart:ChartAdornmentInfo ShowLabel="False"/>
                                    </chart:ColumnSeries.AdornmentsInfo>
                                </chart:ColumnSeries>

                                <!-- Not attended -->
                                <chart:ColumnSeries ItemsSource="{Binding FilteredExamResults}"
                                                XBindingPath="Subject.Name"
                                                YBindingPath="NotAttended"
                                                SegmentSpacing="0.1"
                                                Interior="{StaticResource NotAttendedBrush}"
                                                Label="Not Attended"/>
                            </chart:SfChart>
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="1"
                        Style="{StaticResource GlassCardStyle}">
                        <StackPanel>
                            <TextBlock Text="Grades Distribution"
                                   Style="{StaticResource SectionHeaderStyle}"/>

                            <ItemsControl ItemsSource="{Binding GradeDistributions}"
                                      Margin="0,10,0,0">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal"
                                                HorizontalAlignment="Center"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border CornerRadius="14"
                                            Padding="8,4"
                                            Margin="5,0">
                                            <Border.Background>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                    <GradientStop Color="#FFFFFBEB" Offset="0"/>
                                                    <GradientStop Color="{Binding Color}" Offset="1"/>
                                                </LinearGradientBrush>
                                            </Border.Background>
                                            <StackPanel Orientation="Horizontal" Margin="5,4">
                                                <TextBlock Text="{Binding Grade}"
                                                       Foreground="{StaticResource TextPrimaryBrush}"
                                                       FontWeight="Bold"
                                                       FontSize="16"
                                                       Margin="0,0,5,0"/>
                                                <TextBlock VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}">
                                                <Run Text="{Binding Percentage}"/>
                                                <Run Text="%"/>
                                                </TextBlock>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <TextBlock Text="Grade performance across all subjects"
                                   Style="{StaticResource ScoreLabelStyle}"
                                   HorizontalAlignment="Center"
                                   Margin="20,10,0,0"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>
        </Grid>
    </ScrollViewer>
</Window>
